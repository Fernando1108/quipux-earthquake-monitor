APP_NAME=Quipux Earthquake Monitor
APP_ENV=development
LOG_LEVEL=INFO
MONGO_URI=mongodb://mongodb:27017
MONGO_DATABASE=earthquake_monitor
USGS_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson
USGS_TIMEOUT_SECONDS=15
INGESTION_INTERVAL_SECONDS=180
API_HOST=0.0.0.0
API_PORT=8000
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Airflow local development
# Override credentials and secrets in .env outside local development.
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@airflow-postgres:5432/airflow
AIRFLOW__API_AUTH__JWT_SECRET=quipux-local-airflow-jwt-secret-change-for-production
AIRFLOW__API__SECRET_KEY=quipux-local-airflow-api-secret-change-for-production
AIRFLOW__CORE__FERNET_KEY=
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
